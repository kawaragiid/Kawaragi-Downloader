{
  "manifest_version": 3,
  "name": "Kawaragi Trigger Worker",
  "version": "1.2",
  "description": "Jembatan anti-blokir untuk Kawaragi Downloader",
  "permissions": ["cookies", "tabs", "alarms"],
  "host_permissions": ["<all_urls>", "http://localhost:65432/*"],
  "background": {
    "service_worker": "background.js"
  }
}